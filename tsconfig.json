{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,

    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    "types": ["node", "vite/client"],

    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist", "build", "**/*.test.ts"]
}
